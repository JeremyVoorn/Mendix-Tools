@* Mendix Tools — Dialog (MT-05). Faithful port of
   docs/design-system/components/feedback/Dialog.jsx; styles in
   wwwroot/css/components.css (.mxt-dialog*). Controlled via Open + OnClose.
   Overlay = --overlay + 2px backdrop blur; fade + 8px pop (--duration-normal /
   --ease-out); tone drives the icon tile (accent/warning/danger). Esc and
   overlay-click close; Tab focus is trapped and returned to the trigger on close
   (via wwwroot/js/mxt-interop.js). Renders nothing when closed.
   Usage:
     <Dialog Open="_open" OnClose="() => _open = false" Tone="DialogTone.Warning"
             Icon="alert-triangle" Title="Restore to local Postgres"
             Description="Snapshot from 2026-07-21 (2.4 GB) will be imported.">
         <ChildContent>...form...</ChildContent>
         <Footer>
             <Button Variant="ButtonVariant.Secondary" OnClick="...">Cancel</Button>
             <Button OnClick="...">Start restore</Button>
         </Footer>
     </Dialog> *@
@namespace Mendix_Tools.Components.UI
@implements IAsyncDisposable
@inject IJSRuntime Js

@if (Open)
{
    <div class="mxt-dialog__overlay" @onclick="CloseAsync" @onkeydown="OnKeyDownAsync">
        <div class="mxt-dialog"
             role="dialog"
             aria-modal="true"
             aria-label="@Title"
             tabindex="-1"
             style="width:@(Width)px; max-width:100%;"
             @ref="_dialogRef"
             @onclick:stopPropagation="true"
             @attributes="AdditionalAttributes">
            <div class="mxt-dialog__head">
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <div class="mxt-dialog__icon mxt-dialog__icon--@ToneClass">
                        <Icon Name="@Icon" Size="20" />
                    </div>
                }
                <div class="mxt-dialog__heading">
                    @if (!string.IsNullOrEmpty(Title))
                    {
                        <h3 class="mxt-dialog__title">@Title</h3>
                    }
                    @if (!string.IsNullOrEmpty(Description))
                    {
                        <p class="mxt-dialog__desc">@Description</p>
                    }
                </div>
                <button type="button" class="mxt-dialog__close" aria-label="Close" @onclick="CloseAsync">
                    <Icon Name="x" Size="18" />
                </button>
            </div>
            @if (ChildContent is not null)
            {
                <div class="mxt-dialog__body">@ChildContent</div>
            }
            @if (Footer is not null)
            {
                <div class="mxt-dialog__footer @(ChildContent is null ? "mxt-dialog__footer--nobody" : "")">@Footer</div>
            }
        </div>
    </div>
}

@code {
    private ElementReference _dialogRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _trap;

    /// <summary>Controls visibility (jsx <c>open</c>). Renders nothing when false.</summary>
    [Parameter] public bool Open { get; set; }

    /// <summary>Requested-close callback (jsx <c>onClose</c>) — fired by Esc, the overlay, and the ✕.
    /// The owner flips <see cref="Open"/> in response.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Header title (jsx <c>title</c>).</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Secondary line under the title (jsx <c>description</c>).</summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>Bundled Lucide name for the tone-tinted icon tile (jsx <c>icon</c>). Omit for no tile.</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Icon-tile tone (jsx <c>tone</c>, default accent).</summary>
    [Parameter] public DialogTone Tone { get; set; } = DialogTone.Accent;

    /// <summary>Dialog width in px (jsx <c>width</c>, default 460).</summary>
    [Parameter] public int Width { get; set; } = 460;

    /// <summary>Body slot (jsx <c>children</c>).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Right-aligned footer actions slot (jsx <c>footer</c>).</summary>
    [Parameter] public RenderFragment? Footer { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ToneClass => Tone switch
    {
        DialogTone.Danger => "danger",
        DialogTone.Warning => "warning",
        _ => "accent",
    };

    private Task CloseAsync() => OnClose.InvokeAsync();

    private Task OnKeyDownAsync(KeyboardEventArgs e)
        => e.Key == "Escape" ? OnClose.InvokeAsync() : Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open && _trap is null)
        {
            _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./js/mxt-interop.js");
            _trap = await _module.InvokeAsync<IJSObjectReference>("trapFocus", _dialogRef);
        }
        else if (!Open && _trap is not null)
        {
            await DisposeTrapAsync();
        }
    }

    private async Task DisposeTrapAsync()
    {
        if (_trap is not null)
        {
            try
            {
                await _trap.InvokeVoidAsync("dispose");
                await _trap.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* webview tearing down */ }
            _trap = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeTrapAsync();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
