@* Mendix Tools — app shell (MT-07). Faithful port of
   docs/design-system/ui_kits/app/AppShell.jsx: fixed 248px sidebar (wordmark + "mt"
   tile, "Workspace" nav with Lucide icons, account footer, theme toggle) and fixed 52px
   topbar (per-page title + mono subtitle + right-aligned actions slot) around a scrolling
   content area capped at --content-max and centered. Styles are mxt-* classes appended to
   wwwroot/css/components.css. Per-page topbar content flows in via ShellState/PageHeader;
   the theme toggle persists via ThemeService (MAUI Preferences) and applies data-theme
   through mxt-interop.js. *@
@namespace Mendix_Tools.Components.Layout
@inherits LayoutComponentBase
@inject IJSRuntime Js
@inject ThemeService Theme
@inject ShellState Shell
@implements IAsyncDisposable

<div class="mxt-shell">
    <aside class="mxt-sidebar">
        <div class="mxt-sidebar__brand">
            <div class="mxt-brand-tile">mt</div>
            <div class="mxt-brand-word">Mendix <span class="mxt-brand-word__sub">Tools</span></div>
        </div>

        <nav class="mxt-nav">
            <div class="mxt-nav__eyebrow">Workspace</div>
            @foreach (var item in Nav)
            {
                <NavLink class="mxt-navitem" ActiveClass="mxt-navitem--active"
                         href="@item.Href" Match="NavLinkMatch.All">
                    <Icon Name="@item.Icon" Size="17" />
                    <span>@item.Label</span>
                </NavLink>
            }
        </nav>

        <div class="mxt-sidebar__footer">
            <div class="mxt-avatar">JV</div>
            <div class="mxt-account">
                <div class="mxt-account__name">Jarno V.</div>
                <div class="mxt-account__role">consultant</div>
            </div>
            <Tooltip Label="@(Theme.IsDark ? "Light mode" : "Dark mode")" Placement="TooltipPlacement.Left">
                <IconButton Icon="@(Theme.IsDark ? "sun" : "moon")"
                            AriaLabel="Toggle theme"
                            OnClick="ToggleThemeAsync" />
            </Tooltip>
        </div>
    </aside>

    <div class="mxt-main">
        <header class="mxt-topbar">
            <div class="mxt-topbar__titles">
                <div class="mxt-topbar__title">@Shell.Title</div>
                @if (!string.IsNullOrEmpty(Shell.Subtitle))
                {
                    <div class="mxt-topbar__subtitle">@Shell.Subtitle</div>
                }
            </div>
            <div class="mxt-topbar__actions">@Shell.Actions</div>
        </header>

        <main class="mxt-content">
            <div class="mxt-content__inner">
                @Body
            </div>
        </main>
    </div>
</div>

@* The single app-root toast stack (MT-05). Moved here from Styleguide.razor by MT-15 so
   toasts fired from real routed screens (create-backup / download / restore) render app-wide;
   the singleton ToastService drives it. *@
<ToastStack />

@code {
    private IJSObjectReference? _module;

    private sealed record NavEntry(string Href, string Label, string Icon);

    // Matches AppShell.jsx NAV: Environments is the app home ("/").
    private static readonly NavEntry[] Nav =
    [
        new("", "Environments", "layout-grid"),
        new("backups", "Backups", "database-backup"),
        new("deploy", "Build & Deploy", "rocket"),
        new("databases", "Local Databases", "database"),
        new("settings", "Settings", "settings"),
    ];

    protected override void OnInitialized() => Shell.OnChanged += OnShellChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // Apply the persisted theme via the DOM. The inline boot script in index.html
        // already prevented a flash from the localStorage mirror; this reconciles the
        // attribute against the authoritative MAUI Preferences value.
        _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./js/mxt-interop.js");
        await _module.InvokeVoidAsync("setTheme", Theme.Current);
    }

    private async Task ToggleThemeAsync()
    {
        var next = Theme.Toggle();
        _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./js/mxt-interop.js");
        await _module.InvokeVoidAsync("setTheme", next);
        StateHasChanged(); // refresh the toggle icon + tooltip
    }

    private void OnShellChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        Shell.OnChanged -= OnShellChanged;
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // WebView already torn down — nothing to release.
            }
        }
    }
}
