@* Mendix Tools — Backups list (MT-14, mock-first). Faithful port of
   docs/design-system/ui_kits/app/BackupsScreen.jsx RECONCILED to the live-verified
   Backups API v2 snapshot shape (MT-01 spike, docs/spikes/MT-01-auth-model.md §4):

     • The mock's Size column is CUT — the snapshots API returns no size field.
     • Type is DERIVED from `comment` (Automatic / Pipeline / Manual) — there is no
       API type field; Manual rows show the human comment (truncated, full on hover).
     • Failed snapshots render a danger Badge + their API `status_message`, and have no
       Restore/Download actions.
     • `expires_at` is displayed (retention varies) rather than assumed.
     • Response is the paginated `{ total, snapshots[] }` shape — the page shows the
       total so nothing is silently truncated.

   MT-15 adds the "Create backup" button + active-job progress card (StatusDot pulse +
   ProgressBar + phase text), driven through IJobEngine via BackupJobs; a terminal toast
   states the fact. The action only ever targets the environment selected on screen.

   Data comes from IBackupService (real Backups-v2 client via RealBackupService, behind the
   MT-14 seam). The environment selector is populated from IEnvironmentService (the MT-10
   seam). Restore (MT-17/18) and Download (MT-16) are out of scope here: their row actions
   render DISABLED inside a tooltip until those stories wire them. *@
@page "/backups"
@using Mendix_Tools.Models
@using Mendix_Tools.Services
@using MendixTools.Core.Jobs
@inject IBackupService BackupService
@inject IEnvironmentService EnvService
@inject BackupJobs Jobs
@inject RestoreJobs Restore
@inject IUserNotifier Notifier
@inject AppSettingsService Settings
@inject ShellState Shell
@implements IDisposable

<PageHeader Title="Backups" Subtitle="@_subtitle" Actions="RefreshAction" />

@* Top-level heading for Routes.razor FocusOnNavigate Selector="h1" (visually hidden —
   the visible title lives in the topbar via PageHeader). *@
<h1 class="mxt-visually-hidden">Backups</h1>

<div class="mxt-backups">
    <div class="mxt-backups__controls">
        <Select Label="Source environment"
                Options="_envOptions"
                Value="@_selectedEnvId"
                ValueChanged="OnEnvChangedAsync"
                Style="width:280px"
                Disabled="@(_envOptions.Count == 0 || HasActiveJob)" />
        <div class="mxt-backups__spacer"></div>
        <Button Icon="plus"
                Loading="_creating"
                Disabled="@(_selectedEnvId is null || (HasActiveJob && !_creating))"
                OnClick="CreateBackupAsync">Create backup</Button>
    </div>

    @* Active-job card — one surface for create (MT-15), download (MT-16) AND restore (MT-18).
       Restore drives it in two beats: an indeterminate "Downloading backup" prep state (no Job yet,
       via IBackupService.DownloadArchiveAsync) then the phased restore Job. All card inputs come
       from computed properties so the three flows share one markup (per BackupsScreen.jsx). *@
    @if (ShowCard)
    {
        <Card Padding="15px 16px" class="@ActiveJobCardClass">
            <div class="mxt-jobcard">
                <StatusDot Status="@CardDotStatus" Pulse="@CardRunning" Size="9" />
                <div class="mxt-jobcard__body">
                    <div class="mxt-jobcard__head">
                        <span class="mxt-jobcard__phase">
                            @CardPhase
                            @if (_activeJobContext is not null)
                            {
                                <span class="mxt-jobcard__ctx">· @_activeJobContext</span>
                            }
                        </span>
                        @if (CardPercent is { } p)
                        {
                            <span class="mxt-jobcard__pct">@(Math.Round(p, MidpointRounding.AwayFromZero))%</span>
                        }
                    </div>
                    <ProgressBar Value="@(_activeJob?.Progress ?? 0)"
                                 Indeterminate="@CardIndeterminate"
                                 Tone="@ActiveJobTone"
                                 ShowValue="false" />
                    @if (CardError is not null)
                    {
                        <div class="mxt-jobcard__error">@CardError</div>
                    }
                </div>
                @if (CardTerminal)
                {
                    <Button Size="ControlSize.Sm" Variant="ButtonVariant.Secondary" OnClick="DismissJob">Dismiss</Button>
                }
                else
                {
                    <Button Size="ControlSize.Sm" Variant="ButtonVariant.Secondary" OnClick="CancelJob">Cancel</Button>
                }
            </div>
        </Card>

        @* The restore log is the consultant's main feedback (pg_restore stderr/stdout). Shown under
           the card while a restore runs and kept after it terminates (the "View log" affordance). *@
        @if (_activeJob?.Kind == "restore" && _logLines.Count > 0)
        {
            <LogViewer Lines="_logLines" Title="@($"restore · {_restoreTargetDb}")" Height="200" />
        }
    }

    <Card Title="Cloud backups"
          Subtitle="Restore any snapshot into your local Postgres server"
          Padding="0"
          HeaderActions="ListActions">
        @if (_loading)
        {
            <div class="mxt-backups__state">
                <span class="mxt-spinner" aria-hidden="true"></span>
                <span>Loading backups…</span>
            </div>
        }
        else if (_error is not null)
        {
            <div class="mxt-backups__state" role="alert">
                <span class="mxt-backups__state-icon"><Icon Name="alert-triangle" Size="26" /></span>
                <div class="mxt-backups__state-title">Couldn't load backups for this environment</div>
                <div class="mxt-backups__state-body">@_error</div>
                <Button Variant="ButtonVariant.Secondary" Icon="refresh-cw" OnClick="RefreshAsync">Try again</Button>
            </div>
        }
        else if (_result is null || _result.Snapshots.Count == 0)
        {
            <div class="mxt-backups__state">
                <span class="mxt-backups__state-icon"><Icon Name="database-backup" Size="26" /></span>
                <div class="mxt-backups__state-title">No backups for this environment</div>
                <div class="mxt-backups__state-body">Snapshots taken for this environment will appear here.</div>
            </div>
        }
        else
        {
            <DataTable TRow="Snapshot"
                       Rows="_result.Snapshots"
                       Columns="_columns"
                       RowId="s => s.SnapshotId"
                       Selectable
                       Selected="_selected"
                       SelectedChanged="OnSelectionChanged" />
            <div class="mxt-backups__note">
                Showing @_result.Snapshots.Count of @_result.Total snapshots@(_result.Total > _result.Snapshots.Count ? " · newest page" : "")
            </div>
        }
    </Card>

    @* MT-18 — step one: the configure dialog. Emits the target DB + keep-file choice; starts nothing. *@
    <RestoreDialog Open="_restoreDialogOpen"
                   Created="@_restoreSnapshotCreated"
                   DefaultDatabaseName="@_restoreDefaultDb"
                   KeepFileDefault="@Settings.KeepBackupFilesAfterRestore"
                   OnCancel="CloseRestoreDialog"
                   OnStart="OnRestoreConfigured" />

    @* MT-19 — step two: the Tier-2 typed-identifier guard. ONLY its OnConfirm reaches the
       destructive download+restore. We cannot cheaply probe whether the target DB already exists
       here, so per D5's "when in doubt, guard" we ALWAYS present it (safe default). *@
    <DestructiveConfirm Open="_guardOpen"
                        Title="@($"Drop and recreate {_restoreTargetDb}")"
                        ConsequenceText="@GuardConsequence"
                        TokenLabel="database name"
                        TokenValue="@_restoreTargetDb"
                        ConfirmLabel="Drop and restore"
                        OnConfirm="OnGuardConfirmedAsync"
                        OnClose="CloseGuard" />
</div>

@code {
    private IReadOnlyList<SelectOption> _envOptions = [];
    // EnvironmentId -> keys + provenance the restore/backup calls need. AppName + MendixVersion feed
    // the MT-17 restored-database provenance record (source app / Mendix version).
    private readonly Dictionary<string, (string ProjectId, string Label, string AppName, string? MendixVersion)> _envIndex = new();

    private string? _selectedEnvId;
    private string? _subtitle;

    private BackupListResult? _result;
    private bool _loading = true;
    private bool _refreshing;
    private string? _error;

    private List<object> _selected = [];
    private IReadOnlyList<DataColumn<Snapshot>> _columns = [];

    private CancellationTokenSource _cts = new();

    // Active-job (create / download / restore) card state (MT-15/MT-16/MT-18).
    private Job? _activeJob;
    private string? _activeJobContext;
    private bool _creating;

    // MT-18 restore flow state. The download step (before a Job exists) is shown as an indeterminate
    // "Downloading backup" prep state; _prepError holds a download-step failure (no Job, so it needs
    // its own terminal rendering). _logLines mirrors the restore Job's streamed log for the LogViewer.
    private enum RestorePrep { None, Downloading }
    private RestorePrep _restorePrep = RestorePrep.None;
    private string? _restorePrepError;
    private readonly List<LogLine> _logLines = [];

    private bool _restoreDialogOpen;
    private bool _guardOpen;
    private Snapshot? _restoreSnapshot;
    private string? _restoreSnapshotCreated;
    private string _restoreDefaultDb = string.Empty;
    private string _restoreTargetDb = string.Empty;
    private bool _restoreKeepFile = true;
    private CancellationTokenSource? _restoreCts;

    // Any create/download/restore Job in flight, OR the pre-Job download prep. Gates the Create /
    // Download / Restore actions and the env Select so only one flow runs at a time.
    private bool HasActiveJob => _restorePrep != RestorePrep.None || _activeJob is { IsTerminal: false };

    private string GuardConsequence =>
        $"This drops and recreates `{_restoreTargetDb}`. Open connections will be terminated. This cannot be undone.";

    // ── Active-job card view (unified across the three flows) ────────────────────────────────────
    private bool ShowCard => _activeJob is not null || _restorePrep != RestorePrep.None || _restorePrepError is not null;

    // Actively working: the download prep or a non-terminal Job (drives the pulse + Cancel/Dismiss).
    private bool CardRunning => _restorePrep == RestorePrep.Downloading || _activeJob is { IsTerminal: false };

    private bool CardTerminal => !CardRunning && ShowCard;

    private string CardDotStatus =>
        _restorePrepError is not null || _activeJob?.State == JobState.Failed ? "error"
        : _activeJob?.State == JobState.Succeeded ? "success"
        : "deploying";

    private string CardPhase =>
        _restorePrepError is not null ? "Restore failed"
        : _restorePrep == RestorePrep.Downloading ? "Downloading backup"
        : _activeJob?.CurrentPhase ?? JobKindLabel(_activeJob?.Kind ?? string.Empty);

    // Only the download prep is indeterminate outside a Job; otherwise defer to the Job.
    private bool CardIndeterminate =>
        _restorePrep == RestorePrep.Downloading || (_activeJob?.IsIndeterminate ?? _restorePrepError is not null);

    // A % is shown only for a determinate Job phase (download/create emit real percentages).
    private double? CardPercent =>
        _restorePrep == RestorePrep.None && _activeJob is { IsIndeterminate: false, Progress: { } p } ? p : null;

    private string? CardError =>
        _restorePrepError ?? (_activeJob?.State == JobState.Failed ? _activeJob.Message : null);

    private ProgressTone ActiveJobTone =>
        _restorePrepError is not null ? ProgressTone.Danger
        : _activeJob?.State switch
        {
            JobState.Succeeded => ProgressTone.Success,
            JobState.Failed => ProgressTone.Danger,
            _ => ProgressTone.Db,
        };

    // Splatted onto Card via @attributes; Blazor's last-write-wins on `class` would drop Card's
    // own base class, so we include "mxt-card" here to keep the card surface.
    private string ActiveJobCardClass =>
        _restorePrepError is not null || _activeJob?.State == JobState.Failed
            ? "mxt-card mxt-jobcard-card mxt-jobcard-card--danger"
        : _activeJob?.State == JobState.Succeeded
            ? "mxt-card mxt-jobcard-card mxt-jobcard-card--success"
            : "mxt-card mxt-jobcard-card mxt-jobcard-card--active";

    protected override async Task OnInitializedAsync()
    {
        _columns = BuildColumns();
        await LoadEnvironmentsAsync();
        await LoadSnapshotsAsync();
    }

    private async Task LoadEnvironmentsAsync()
    {
        _envIndex.Clear();
        var options = new List<SelectOption>();

        // The env Select is populated from the same seam MT-20 wired. On any non-Ok outcome
        // (no creds / rejected / offline) the apps list is empty → no environment is
        // selectable → LoadSnapshotsAsync short-circuits to the calm empty state. The
        // credential-rejected story is surfaced prominently on the Environments dashboard.
        var envResult = await EnvService.GetAppsAsync(_cts.Token);
        foreach (var app in envResult.Apps)
        {
            foreach (var env in app.Environments)
            {
                var label = $"{app.Name} · {env.Mode}";
                _envIndex[env.EnvironmentId] = (app.ProjectId, label, app.Name, env.MendixVersion);
                options.Add(new SelectOption(env.EnvironmentId, label));
            }
        }

        _envOptions = options;
        _selectedEnvId ??= options.FirstOrDefault()?.Value;
    }

    private async Task LoadSnapshotsAsync()
    {
        _loading = true;
        _error = null;
        _selected = [];

        if (_selectedEnvId is null || !_envIndex.TryGetValue(_selectedEnvId, out var env))
        {
            _result = BackupListResult.Empty;
            _loading = false;
            _subtitle = null;
            return;
        }

        _subtitle = env.Label;
        Shell.SetHeader("Backups", _subtitle, RefreshAction);

        try
        {
            _result = await BackupService.GetSnapshotsAsync(env.ProjectId, _selectedEnvId, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            return; // superseded by a reload / navigation away
        }
        catch (Exception ex)
        {
            // Never surface a raw exception — state what happened + what to do next.
            _result = null;
            _error = MapError(ex);
        }

        _loading = false;
    }

    private async Task OnEnvChangedAsync(string? envId)
    {
        _selectedEnvId = envId;
        // Cancel any in-flight load before starting the new one.
        ResetCts();
        await LoadSnapshotsAsync();
    }

    private Task OnSelectionChanged(IReadOnlyList<object> selected)
    {
        _selected = [.. selected];
        return Task.CompletedTask;
    }

    // ── MT-15 create backup ────────────────────────────────────────────────────────────

    private void CreateBackupAsync()
    {
        if (_selectedEnvId is null || !_envIndex.TryGetValue(_selectedEnvId, out var env) || HasActiveJob)
        {
            return;
        }

        _creating = true;
        var job = Jobs.StartCreateBackup(env.ProjectId, _selectedEnvId, env.Label);
        TrackJob(job, env.Label);
    }

    // ── MT-16 download backup ──────────────────────────────────────────────────────────
    // Starts a single-snapshot download job through the SAME active-job card MT-15 built.
    // Download is disabled while any job runs (kept simple — no concurrent jobs).

    private void StartDownload(Snapshot snap)
    {
        if (_selectedEnvId is null || !_envIndex.TryGetValue(_selectedEnvId, out var env) || HasActiveJob)
        {
            return;
        }

        // Where the archive lands: the configured data directory, or a sensible app-data default
        // when the user hasn't set one in Settings › Database. The job creates it if missing.
        var dir = Settings.DataDirectory;
        if (string.IsNullOrWhiteSpace(dir))
        {
            dir = Path.Combine(Microsoft.Maui.Storage.FileSystem.AppDataDirectory, "backups");
        }

        var options = new DownloadOptions(dir, Settings.VerifyChecksumAfterDownload, Settings.KeepBackupFilesAfterRestore);
        var job = Jobs.StartDownload(env.ProjectId, _selectedEnvId, snap.SnapshotId, env.Label, options);
        TrackJob(job, $"{env.Label} · {snap.CreatedAt:yyyy-MM-dd HH:mm}");
    }

    // ── Active-job card plumbing ─────────────────────────────────────────────────────────

    private void TrackJob(Job job, string context)
    {
        DetachJob(); // only one card at a time
        _activeJob = job;
        _activeJobContext = context;
        // Seed from any lines already emitted before this subscription (fast/fake jobs), then stream.
        _logLines.Clear();
        foreach (var line in job.Log)
        {
            _logLines.Add(MapLog(line));
        }

        job.StateChanged += OnJobStateChanged;
        job.ProgressChanged += OnJobProgressChanged;
        job.LineAppended += OnJobLine;
        StateHasChanged();
    }

    private void OnJobProgressChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    private void OnJobLine(object? sender, JobLogLine line) => InvokeAsync(() =>
    {
        _logLines.Add(MapLog(line));
        StateHasChanged();
    });

    // Maps a core job log line to the LogViewer's LogLine (level + local HH:mm:ss timestamp).
    private static LogLine MapLog(JobLogLine line) => new(
        line.Message,
        line.Level switch
        {
            JobLogLevel.Warning => LogLevel.Warn,
            JobLogLevel.Error => LogLevel.Error,
            JobLogLevel.Debug => LogLevel.Debug,
            _ => LogLevel.Info,
        },
        line.Timestamp.ToLocalTime().ToString("HH:mm:ss"));

    private async void OnJobStateChanged(object? sender, JobStateChangedEventArgs e)
    {
        if (e.Current is JobState.Succeeded or JobState.Failed or JobState.Cancelled)
        {
            _creating = false;
            // A completed create leaves a new snapshot in the list — refresh it (download does not).
            if (e.Current == JobState.Succeeded && _activeJob?.Kind == "create-backup")
            {
                await LoadSnapshotsAsync();
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void DismissJob()
    {
        DetachJob();
        _activeJob = null;
        _activeJobContext = null;
        _creating = false;
        _restorePrep = RestorePrep.None;
        _restorePrepError = null;
        _logLines.Clear();
    }

    private void CancelJob()
    {
        if (_activeJob is { IsTerminal: false })
        {
            // BackupJobs.Cancel and RestoreJobs.Cancel both delegate to the same singleton
            // IJobEngine, so this cancels a create/download OR a restore job by id.
            Jobs.Cancel(_activeJob.Id);
        }
        else if (_restorePrep == RestorePrep.Downloading)
        {
            // No Job yet — cancel the in-flight archive download via its dedicated token.
            _restoreCts?.Cancel();
        }
    }

    private void DetachJob()
    {
        if (_activeJob is not null)
        {
            _activeJob.StateChanged -= OnJobStateChanged;
            _activeJob.ProgressChanged -= OnJobProgressChanged;
            _activeJob.LineAppended -= OnJobLine;
        }
    }

    // ── MT-18 restore: configure dialog → MT-19 guard → download → RestoreJobs.StartRestore ──────

    private void OpenRestoreDialog(Snapshot snap)
    {
        if (!snap.HasActions || HasActiveJob
            || _selectedEnvId is null || !_envIndex.TryGetValue(_selectedEnvId, out var env))
        {
            return;
        }

        _restoreSnapshot = snap;
        _restoreSnapshotCreated = snap.CreatedAt.ToString("yyyy-MM-dd HH:mm");
        _restoreDefaultDb = DefaultDatabaseName(env.AppName);
        _restoreDialogOpen = true;
    }

    private void CloseRestoreDialog() => _restoreDialogOpen = false;

    // Step one done: the user configured the restore. Because we cannot cheaply tell whether the
    // target DB already exists, we ALWAYS present the Tier-2 guard (safe default — D5). Only its
    // OnConfirm proceeds; Cancel/Esc leaves Postgres untouched.
    private void OnRestoreConfigured(RestoreDialogResult result)
    {
        _restoreDialogOpen = false;
        _restoreTargetDb = result.TargetDatabaseName;
        _restoreKeepFile = result.KeepFile;
        _guardOpen = true;
    }

    private void CloseGuard() => _guardOpen = false;

    private async Task OnGuardConfirmedAsync()
    {
        _guardOpen = false;
        await RunRestoreAsync();
    }

    // Download the archive (composable MT-16 seam, shown as the indeterminate "Downloading backup"
    // prep state) then hand the local file to the MT-17 restore engine as a phased Job. confirmed:
    // true is the guard's pass — the destructive drop/recreate is reachable ONLY on this path.
    private async Task RunRestoreAsync()
    {
        if (_restoreSnapshot is null
            || _selectedEnvId is null || !_envIndex.TryGetValue(_selectedEnvId, out var env))
        {
            return;
        }

        var snap = _restoreSnapshot;
        var targetDb = _restoreTargetDb;
        var keepFile = _restoreKeepFile;
        var created = snap.CreatedAt.ToString("yyyy-MM-dd HH:mm");

        var dir = Settings.DataDirectory;
        if (string.IsNullOrWhiteSpace(dir))
        {
            dir = Path.Combine(Microsoft.Maui.Storage.FileSystem.AppDataDirectory, "backups");
        }

        // Show the card immediately in its download-prep state and disable the row actions.
        DetachJob();
        _activeJob = null;
        _logLines.Clear();
        _restorePrepError = null;
        _restorePrep = RestorePrep.Downloading;
        _activeJobContext = $"{targetDb} · {created}";

        // Dedicated token so the shared _cts (reset by env-change / topbar Refresh) can't cancel the
        // download from under the restore; the card's Cancel button cancels this one.
        _restoreCts?.Dispose();
        _restoreCts = new CancellationTokenSource();
        var ct = _restoreCts.Token;
        StateHasChanged();

        BackupDownload download;
        try
        {
            download = await BackupService.DownloadArchiveAsync(
                env.ProjectId, _selectedEnvId, snap.SnapshotId, dir, Settings.VerifyChecksumAfterDownload, ct);
        }
        catch (OperationCanceledException)
        {
            _restorePrep = RestorePrep.None; // user cancelled the download — nothing was restored
            return;
        }
        catch (Exception ex)
        {
            _restorePrep = RestorePrep.None;
            _restorePrepError = MapError(ex);
            Notifier.Error("Restore failed", _restorePrepError);
            StateHasChanged();
            return;
        }

        _restorePrep = RestorePrep.None;

        var provenance = new RestoreProvenanceInfo(env.AppName, _selectedEnvId, env.MendixVersion, snap.CreatedAt);
        var job = Restore.StartRestore(
            download.FilePath, targetDb, snap.SnapshotId, env.Label,
            confirmed: true, keepFile: keepFile, provenance: provenance);

        // Drive the same card; the restore Job's phases/log/toast take over from here.
        TrackJob(job, $"{targetDb} · {created}");
    }

    // Derives a sensible default local database name from the source app name, e.g.
    // "Acme Insurance" -> "acme_insurance_local". The user can edit it in the dialog; the final
    // value is what the guard requires typed.
    private static string DefaultDatabaseName(string appName)
    {
        if (string.IsNullOrWhiteSpace(appName))
        {
            return "restored_local";
        }

        var slug = new string(appName.Trim().ToLowerInvariant()
            .Select(c => char.IsLetterOrDigit(c) ? c : '_').ToArray());
        while (slug.Contains("__"))
        {
            slug = slug.Replace("__", "_");
        }

        slug = slug.Trim('_');
        return string.IsNullOrEmpty(slug) ? "restored_local" : $"{slug}_local";
    }

    private static string JobKindLabel(string kind) => kind switch
    {
        "create-backup" => "Creating backup",
        "download" => "Downloading backup",
        "restore" => "Restoring",
        _ => kind,
    };

    private async Task RefreshAsync()
    {
        if (_refreshing)
        {
            return;
        }

        ResetCts();
        _refreshing = true;
        Shell.SetHeader("Backups", _subtitle, RefreshAction); // show the spinner

        try
        {
            await LoadSnapshotsAsync();
        }
        catch (OperationCanceledException)
        {
            return;
        }
        finally
        {
            _refreshing = false;
            Shell.SetHeader("Backups", _subtitle, RefreshAction); // clear the spinner
        }
    }

    private void ResetCts()
    {
        _cts.Cancel();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
    }

    private RenderFragment RefreshAction => @<Button Variant="ButtonVariant.Secondary"
                                                     Icon="refresh-cw"
                                                     Loading="_refreshing"
                                                     OnClick="RefreshAsync">Refresh</Button>;

    // Bulk-download affordance. Shown only with a selection; DISABLED in this version — MT-16
    // ships single-snapshot download (the row action). Bulk/sequential download is out of scope.
    private RenderFragment ListActions =>
    @<text>
        @if (_selected.Count > 0)
        {
            <Tooltip Label="Bulk download isn't available in this version — download snapshots one at a time.">
                <Button Size="ControlSize.Sm" Variant="ButtonVariant.Secondary" Icon="download" Disabled>
                    Download @_selected.Count
                </Button>
            </Tooltip>
        }
    </text>;

    private List<DataColumn<Snapshot>> BuildColumns() =>
    [
        new DataColumn<Snapshot>
        {
            Key = "created", Header = "Created", Mono = true,
            Value = s => s.CreatedAt.ToString("yyyy-MM-dd HH:mm"),
        },
        new DataColumn<Snapshot>
        {
            Key = "type", Header = "Type",
            Render = snap =>
        @<div class="mxt-backups__type">
            <Badge Tone="@TypeTone(snap.Type)" Size="BadgeSize.Sm">@TypeLabel(snap.Type)</Badge>
            @if (snap.Type == SnapshotType.Manual && !string.IsNullOrWhiteSpace(snap.Comment))
            {
                <span class="mxt-backups__comment" title="@snap.Comment">@snap.Comment</span>
            }
        </div>,
        },
        new DataColumn<Snapshot>
        {
            Key = "state", Header = "State",
            Render = snap =>
        @<div class="mxt-backups__state-cell">
            <Badge Tone="@StateTone(snap.State)"
                   Dot="@(snap.State is SnapshotState.Completed or SnapshotState.Running)"
                   Size="BadgeSize.Sm">@StateLabel(snap.State)</Badge>
            @if (snap.State == SnapshotState.Failed && !string.IsNullOrWhiteSpace(snap.StatusMessage))
            {
                <span class="mxt-backups__statusmsg" title="@snap.StatusMessage">@snap.StatusMessage</span>
            }
        </div>,
        },
        new DataColumn<Snapshot>
        {
            Key = "expires", Header = "Expires", Mono = true,
            Value = s => s.ExpiresAt?.ToString("yyyy-MM-dd") ?? "—",
        },
        new DataColumn<Snapshot>
        {
            Key = "actions", Header = "", Align = ColumnAlign.Right, Width = "180px",
            Render = snap =>
        @<div class="mxt-backups__actions">
            @if (snap.HasActions)
            {
                @* MT-18 — Restore this completed snapshot into local Postgres. Opens the configure
                   dialog; "Start restore" there routes through the MT-19 typed-identifier guard
                   before anything touches the database. Disabled while any job/prep runs. *@
                <Button Size="ControlSize.Sm" Variant="ButtonVariant.Subtle" Icon="database-backup"
                        Disabled="@HasActiveJob"
                        OnClick="@(() => OpenRestoreDialog(snap))">Restore</Button>
                @* MT-16 — Download the snapshot's database-only archive to the data directory,
                   driven through the same active-job card. Disabled while a job runs. *@
                <IconButton Size="ControlSize.Sm" Icon="download" AriaLabel="Download"
                            Disabled="@HasActiveJob"
                            OnClick="@(() => StartDownload(snap))" />
            }
        </div>,
        },
    ];

    private static string TypeLabel(SnapshotType t) => t switch
    {
        SnapshotType.Automatic => "Automatic",
        SnapshotType.Pipeline => "Pipeline",
        _ => "Manual",
    };

    private static BadgeTone TypeTone(SnapshotType t) => t switch
    {
        SnapshotType.Automatic => BadgeTone.Info,
        SnapshotType.Pipeline => BadgeTone.Accent,
        _ => BadgeTone.Neutral,
    };

    private static string StateLabel(SnapshotState s) => s switch
    {
        SnapshotState.Completed => "Available",
        SnapshotState.Failed => "Failed",
        SnapshotState.Running => "Running",
        _ => "Queued",
    };

    private static BadgeTone StateTone(SnapshotState s) => s switch
    {
        SnapshotState.Completed => BadgeTone.Success,
        SnapshotState.Failed => BadgeTone.Danger,
        SnapshotState.Running => BadgeTone.Accent,
        _ => BadgeTone.Neutral, // Queued
    };

    // Maps the (mock) failure into a calm "what happened + what to do next" line —
    // MT-20's real client throws the same shapes (timeout / HTTP status), so this mapping
    // carries forward. Never renders a stack trace.
    private static string MapError(Exception ex) => ex switch
    {
        TimeoutException => "The request timed out. Check your connection, then Refresh.",
        HttpRequestException => "Couldn't reach the Mendix API. Check your connection and Settings › Credentials, then Refresh.",
        UnauthorizedAccessException => "Credential rejected — check Settings › Credentials.",
        _ => "Something went wrong loading this environment. Check Settings › Credentials, then Refresh.",
    };

    public void Dispose()
    {
        // Detach the job-event subscriptions; the job itself keeps running in the singleton
        // engine (survives navigation) and its terminal toast still fires via BackupJobs.
        DetachJob();
        _cts.Cancel();
        _cts.Dispose();
        // Cancel an in-flight restore download; the restore Job itself lives in the singleton engine
        // and survives navigation (its terminal toast still fires).
        _restoreCts?.Cancel();
        _restoreCts?.Dispose();
    }
}
